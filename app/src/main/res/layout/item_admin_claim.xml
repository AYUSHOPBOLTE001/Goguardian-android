<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/surface_elevated"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/text_claim_ride_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ride ID: #12345"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_claim_reason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_amber"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="SOS Alert"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_claim_route"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pickup → Dropoff"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/text_claim_fare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fare: ₹450"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_process_refund"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Process Refund"
            android:textColor="@color/success"
            app:icon="@drawable/ic_wallet"
            app:iconTint="@color/success" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
