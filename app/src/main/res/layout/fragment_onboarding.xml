<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Cyan glow top-right -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/bg_glow_cyan"
        android:alpha="0.12"
        android:layout_marginTop="-180dp"
        android:layout_marginEnd="-160dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Magenta glow bottom-left -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_magenta"
        android:alpha="0.10"
        android:layout_marginStart="-120dp"
        android:layout_marginBottom="-120dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Logo row -->
    <LinearLayout
        android:id="@+id/logo_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="48dp"
        android:layout_marginStart="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/primary"
            app:cardElevation="0dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="G"
                android:textColor="@color/text_on_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="GoGuardian"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <!-- Skip button -->
    <TextView
        android:id="@+id/button_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="28dp"
        android:text="Skip"
        android:textColor="@color/text_tertiary"
        android:textSize="14sp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewpager_onboarding"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/logo_row"
        app:layout_constraintBottom_toTopOf="@id/dot_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dot indicator -->
    <LinearLayout
        android:id="@+id/dot_indicator"
        android:layout_width="wrap_content"
        android:layout_height="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/button_next"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp">

        <View android:id="@+id/dot_0" android:layout_width="10dp" android:layout_height="10dp"
            android:background="@drawable/bg_dot_warning" android:layout_marginHorizontal="5dp" />
        <View android:id="@+id/dot_1" android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/bg_pill_teal" android:layout_marginHorizontal="5dp" android:alpha="0.4" />
        <View android:id="@+id/dot_2" android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/bg_pill_teal" android:layout_marginHorizontal="5dp" android:alpha="0.4" />
    </LinearLayout>

    <!-- Next / Get Started button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_next"
        style="@style/Widget.GoGuardian.Button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="48dp"
        android:text="NEXT"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:iconGravity="end"
        app:icon="@drawable/ic_arrow_forward"
        app:iconTint="@color/text_on_primary" />

</androidx.constraintlayout.widget.ConstraintLayout>
