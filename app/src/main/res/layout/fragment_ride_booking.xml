<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Map remains the base layer -->
    <fragment
        android:id="@+id/booking_map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Header Search Card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/surface_overlay"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_strong">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Pickup -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_location_pin"
                app:startIconTint="@color/success">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/input_pickup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/current_location"
                    android:textColor="@color/text_primary"
                    android:paddingVertical="12dp"
                    android:background="@android:color/transparent"
                    android:textSize="15sp"
                    android:completionThreshold="1"
                    android:imeOptions="actionNext"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginStart="44dp" />

            <!-- Dropoff -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@android:color/transparent"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_location_pin"
                app:startIconTint="@color/secondary">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/input_dropoff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Where to?"
                    android:textColor="@color/text_primary"
                    android:paddingVertical="12dp"
                    android:background="@android:color/transparent"
                    android:textSize="15sp"
                    android:completionThreshold="1"
                    android:imeOptions="actionDone"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Bottom Booking Sheet ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_sheet_booking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/surface_overlay"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_strong"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="@color/divider"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_estimate"
                style="@style/Widget.GoGuardian.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Locations" />

            <!-- Vehicle selection (hidden until estimate) -->
            <LinearLayout
                android:id="@+id/section_vehicles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- GoKab -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_cab"
                            android:layout_width="128dp"
                            android:layout_height="156dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="22dp"
                            app:strokeWidth="2dp"
                            app:strokeColor="@color/primary">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/bg_vehicle_icon_cab">
                                    <ImageView
                                        android:layout_width="44dp"
                                        android:layout_height="44dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_car_enhanced" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GoKab"
                                    android:textStyle="bold"
                                    android:layout_marginTop="8dp" />
                                <TextView
                                    android:id="@+id/text_cab_fare"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹--"
                                    android:textColor="@color/primary"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/text_cab_eta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-- min"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_tertiary" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- GoBike -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_bike"
                            android:layout_width="128dp"
                            android:layout_height="156dp"
                            android:layout_marginEnd="12dp"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="22dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/border">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/bg_vehicle_icon_bike">
                                    <ImageView
                                        android:layout_width="44dp"
                                        android:layout_height="44dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_motorcycle_enhanced" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GoBike"
                                    android:textStyle="bold"
                                    android:layout_marginTop="8dp" />
                                <TextView
                                    android:id="@+id/text_bike_fare"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹--"
                                    android:textColor="@color/teal"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/text_bike_eta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-- min"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_tertiary" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- GoAuto -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/card_auto"
                            android:layout_width="128dp"
                            android:layout_height="156dp"
                            app:cardBackgroundColor="@color/surface"
                            app:cardCornerRadius="22dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/border">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/bg_vehicle_icon_auto">
                                    <ImageView
                                        android:layout_width="44dp"
                                        android:layout_height="44dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_auto_enhanced" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GoAuto"
                                    android:textStyle="bold"
                                    android:layout_marginTop="8dp" />
                                <TextView
                                    android:id="@+id/text_auto_fare"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹--"
                                    android:textColor="@color/warning"
                                    android:textStyle="bold" />
                                <TextView
                                    android:id="@+id/text_auto_eta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-- min"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_tertiary" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Bid Your Price -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BID YOUR PRICE"
                                android:textColor="@color/text_tertiary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Optional · driver may decline if too low"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:hint="₹ amount"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_bid_price"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLength="5" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_book"
                    style="@style/Widget.GoGuardian.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Confirm Grokride" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
