<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ Neo-Brutalist Geometric Background ══ -->

    <!-- Cyan glow - top right -->
    <View
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:background="@drawable/bg_glow_cyan"
        android:alpha="0.15"
        android:layout_marginTop="-250dp"
        android:layout_marginEnd="-200dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Magenta accent - bottom left -->
    <View
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:background="@drawable/bg_glow_magenta"
        android:alpha="0.12"
        android:layout_marginStart="-150dp"
        android:layout_marginBottom="-150dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Sharp diagonal accent line -->
    <View
        android:layout_width="4dp"
        android:layout_height="200dp"
        android:background="@color/primary"
        android:alpha="0.3"
        android:rotation="25"
        android:layout_marginEnd="80dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ══ Center Brand Identity – Bold & Geometric ══ -->
    <LinearLayout
        android:id="@+id/brand_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_group"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Sharp geometric logo container -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_logo_brutalist">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="G"
                android:textColor="@color/text_on_primary"
                android:textSize="64sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.03"
                android:includeFontPadding="false" />
        </FrameLayout>

        <!-- App name – Bold display -->
        <TextView
            android:id="@+id/welcome_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.03"
            android:includeFontPadding="false" />

        <!-- Tagline – Sharp contrast -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_tagline"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium" />

        <!-- Demo banner – High contrast pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_warning_sharp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_warning" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="DEMO MODE · NO REAL RIDES"
                android:textColor="@color/text_on_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══ Bottom Loading Group – Minimal ══ -->
    <LinearLayout
        android:id="@+id/bottom_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/primary"
            app:trackColor="@color/surface_variant"
            app:indicatorSize="40dp"
            app:trackThickness="3dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/version_text"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:letterSpacing="0.08"
            android:fontFamily="monospace" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
